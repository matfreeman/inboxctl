{
  "name": "inboxctl",
  "version": "0.7.3",
  "description": "MCP-native Gmail management CLI with rules-as-code, audit logging, and a full-screen TUI",
  "type": "module",
  "license": "MIT",
  "author": "Matthew Freeman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matfreeman/inboxctl.git"
  },
  "homepage": "https://github.com/matfreeman/inboxctl",
  "bugs": {
    "url": "https://github.com/matfreeman/inboxctl/issues"
  },
  "keywords": [
    "gmail",
    "email",
    "mcp",
    "cli",
    "tui",
    "rules-as-code",
    "model-context-protocol",
    "ai",
    "automation"
  ],
  "bin": {
    "inboxctl": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "rules/example.yaml",
    ".env.example"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "node dist/cli.js demo",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INBOXCTL_INTEGRATION=1 vitest run src/__tests__/integration/",
    "test:mcp": "vitest run src/__tests__/mcp/",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@googleapis/gmail": "^14.0.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "google-auth-library": "^9.15.0",
    "html-to-text": "^9.0.0",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^10.1.0",
    "react": "^18.3.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/html-to-text": "^9.0.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "^3.1.0",
    "drizzle-kit": "^0.30.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
